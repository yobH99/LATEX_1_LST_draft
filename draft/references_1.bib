  shorttitle = {A Comparative Study of the Turbulent {{Rayleigh}}--{{Taylor}} Instability Using High-Resolution Three-Dimensional Numerical Simulations},
  author = {Dimonte, G. and Youngs, D. L. and Dimits, A. and Weber, S. and Marinak, M. and Wunsch, S. and Garasi, C. and Robinson, A. and Andrews, M. J. and Ramaprabhu, P. and Calder, A. C. and Fryxell, B. and Biello, J. and Dursi, L. and MacNeice, P. and Olson, K. and Ricker, P. and Rosner, R. and Timmes, F. and Tufo, H. and Young, Y.-N. and Zingale, M.},
